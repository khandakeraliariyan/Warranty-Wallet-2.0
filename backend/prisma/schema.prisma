generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum UserPlan {
  FREE
  PREMIUM
}

enum WarrantyStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
}

enum WarrantyType {
  MANUFACTURER
  EXTENDED
}

enum NotificationType {
  REMINDER
  PAYMENT
  SUBSCRIPTION
  SYSTEM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ActivityType {
  LOGIN
  REGISTER
  PROFILE_UPDATED

  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED

  DOCUMENT_UPLOADED
  DOCUMENT_DELETED

  PAYMENT_SUCCESS
  PAYMENT_FAILED

  SUBSCRIPTION_CREATED
  SUBSCRIPTION_EXPIRED

  USER_BLOCKED
  USER_UNBLOCKED
  USER_DELETED

  ADMIN_PRODUCT_DELETED
  ADMIN_BROADCAST
}

model User {
  id String @id @default(cuid())

  firebaseUid String @unique

  name String

  email String @unique

  phone String?

  photoURL String?

  emailVerified Boolean @default(false)

  role UserRole @default(USER)

  status UserStatus @default(ACTIVE)

  plan UserPlan @default(FREE)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  products Product[]

  documents Document[]

  notifications Notification[]

  activityLogs ActivityLog[]

  payments Payment[]

  subscription Subscription?

  @@index([role])
  @@index([status])
  @@index([plan])
  @@index([createdAt])
}

model Category {
  id String @id @default(cuid())

  name String @unique

  slug String @unique

  icon String?

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id String @id @default(cuid())

  userId String

  categoryId String

  name String

  brand String

  model String?

  serialNumber String?

  barcode String?

  purchasePrice Decimal @db.Decimal(10, 2)

  purchaseDate DateTime

  warrantyDuration Int

  warrantyType WarrantyType

  expiryDate DateTime

  status WarrantyStatus @default(ACTIVE)

  sellerName String?

  sellerPhone String?

  sellerEmail String?

  sellerAddress String?

  productImageUrl String?

  productImagePublicId String?

  notes String?

  approvedById String?

  approvedAt DateTime?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category Category @relation(fields: [categoryId], references: [id])

  documents Document[]

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([expiryDate])
  @@index([purchaseDate])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([userId, status])
}

model Document {
  id String @id @default(cuid())

  userId String

  productId String

  fileName String

  fileType String

  fileSize Int?

  fileUrl String

  publicId String

  provider String

  invoiceNumber String?

  vendorName String?

  ocrProcessed Boolean @default(false)

  ocrConfidence Float?

  ocrRaw Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
  @@index([ocrProcessed])
  @@index([createdAt])
}

model Notification {
  id String @id @default(cuid())

  userId String

  title String

  message String

  type NotificationType

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, isRead])
}

model Subscription {
  id String @id @default(cuid())

  userId String @unique

  latestPaymentId String? @unique

  stripeCustomerId String?

  plan UserPlan

  status SubscriptionStatus @default(ACTIVE)

  startsAt DateTime

  expiresAt DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  latestPayment Payment? @relation("LatestSubscriptionPayment", fields: [latestPaymentId], references: [id])

  @@index([status])
  @@index([expiresAt])
}

model Payment {
  id String @id @default(cuid())

  userId String

  stripeSessionId String @unique

  stripePaymentIntent String?

  amount Decimal @db.Decimal(10, 2)

  currency String

  paymentMethod String

  status PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  latestSubscription Subscription? @relation("LatestSubscriptionPayment")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model ActivityLog {
  id String @id @default(cuid())

  userId String

  type ActivityType

  entity String

  entityId String?

  title String

  description String?

  metadata Json?

  ipAddress String?

  userAgent String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([type])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model WebhookEvent {
  id String @id @default(cuid())

  stripeEventId String @unique

  eventType String

  processed Boolean @default(false)

  payload Json

  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([processed])
}
